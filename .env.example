# Copy to .env and fill in your values, then source it before running:
#   cp .env.example .env
#   set -a; source .env; set +a
#   python3 bot.py

# Telegram bot token from @BotFather
BOT_TOKEN=your-bot-token-here

# Nopecha API key from https://nopecha.com
NOPECHA_API_KEY=your-nopecha-key-here

# Optional: 0 = show browser window (debug), 1 = headless (production)
HEADLESS=1

# Optional: session storage directory
SESSION_DIR=sessions
